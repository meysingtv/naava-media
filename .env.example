# Supabase – im Supabase Dashboard unter "Project Settings" → "API" zu finden
# Diese Werte sind öffentlich (anon key) und dürfen im Browser verwendet werden.
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Basis-URL der App (für E-Mail-Bestätigungs- und Einladungslinks).
# Lokal: http://localhost:3000 – auf Vercel: https://deine-domain.de
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Service-Role-Key (NUR serverseitig, NIE im Browser!).
# Wird später für Fahrlehrer-Einladungen per E-Mail benötigt.
# SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key
