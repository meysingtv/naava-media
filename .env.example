# Supabase – im Supabase Dashboard unter "Project Settings" → "API" zu finden
# Diese Werte sind öffentlich (anon key) und dürfen im Browser verwendet werden.
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Basis-URL der App (für E-Mail-Bestätigungs- und Einladungslinks).
# Diese URL landet in den Mails – sie muss von dem Gerät erreichbar sein,
# das die Mail öffnet (z. B. Handy im selben WLAN -> die LAN-IP nehmen):
#   Lokal am selben PC:        http://localhost:3000
#   Test mit Handy/Tablet:     http://192.168.178.78:3000
#   Produktion (Vercel):       https://deine-domain.de
# Wichtig: Dieselbe URL in Supabase unter Auth -> URL Configuration
# als "Redirect URL" (z. B. http://192.168.178.78:3000/**) eintragen.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service-Role-Key (NUR serverseitig, NIE im Browser!).
# Aktiviert die Fahrlehrer-Einladung per E-Mail. Zu finden unter
# Project Settings -> API -> "Legacy" oder "service_role". Optional.
# SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key
